{
  "name": "mynumber",
  "version": "1.0.0",
  "private": true,
  "description": "Number combination puzzle solver — C++ library, Node.js addon, and WebAssembly",
  "main": "src/node/index.js",
  "types": "src/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/node/index.d.ts",
      "require": "./src/node/index.js",
      "default": "./src/node/index.js"
    },
    "./wasm": {
      "types": "./src/emscripten/index.d.ts",
      "require": "./src/emscripten/index.js",
      "default": "./src/emscripten/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lordofdestiny/mynumber.git"
  },
  "scripts": {
    "install": "node -e \"process.exit(0)\"",
    "build": "npm run build:node && npm run build:wasm",
    "build:native": "make native dist-native",
    "build:lib": "make native",
    "build:main": "make native main",
    "build:node": "make dist-node",
    "build:wasm": "make dist-wasm",
    "build:demo": "make dist-demo",
    "build:js-fallback": "tsx scripts/compile-js-fallback.mjs",
    "build:all": "npm run build:js-fallback && make native dist-node dist-wasm dist-demo dist-npm",
    "stage:npm": "node scripts/stage-npm-packages.mjs",
    "package:prebuild": "node scripts/package-prebuild.mjs",
    "lint:packages": "publint dist/npm/mynumber && publint dist/npm/mynumber-wasm",
    "demo": "npm run build:demo && npx --yes serve dist/demo -l 8080",
    "clean": "make clean",
    "app": "make native main && ./build/native/mynumber",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.js-fallback.json --noEmit",
    "pretest": "npm run build:node && npm run build:wasm && npm run build:js-fallback",
    "test": "npm run typecheck && node --test test/**/*.test.js",
    "test:consumer": "npm run setup --prefix ../mynumber-test && npm run test --prefix ../mynumber-test",
    "start": "node -e \"const { Combination } = require('.'); const c = Combination.generate(); console.log(c.solve())\""
  },
  "keywords": [
    "native",
    "addon",
    "wasm",
    "emscripten",
    "number-puzzle"
  ],
  "author": "lordofdestiny",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.4.0"
  },
  "devDependencies": {
    "@mapbox/node-pre-gyp": "^2.0.0",
    "@types/node": "^25.9.3",
    "node-pre-gyp-github": "^2.0.0",
    "publint": "^0.3.0",
    "typescript": "^6.0.3",
    "tsx": "^4.19.0"
  }
}
